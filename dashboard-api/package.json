{
  "name": "sytra-mcp-dashboard-api",
  "version": "1.0.0",
  "description": "Backend API for Sytra MCP Management Dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node test/api.test.js",
    "test:watch": "nodemon --exec 'npm test'",
    "lint": "echo 'Linting not configured yet'",
    "docker:build": "docker build -t sytra-dashboard-api .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop sytra-dashboard-api",
    "pm2:restart": "pm2 restart sytra-dashboard-api",
    "pm2:logs": "pm2 logs sytra-dashboard-api"
  },
  "keywords": [
    "mcp",
    "dashboard",
    "monitoring",
    "api"
  ],
  "author": "Sytra MCP Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "ws": "^8.14.2",
    "sql.js": "^1.10.3",
    "bcrypt": "^5.1.1",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}