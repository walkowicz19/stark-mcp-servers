# Sytra MCP Dashboard API - Environment Configuration

# Server Configuration
PORT=3000
HOST=localhost
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=*

# Database Configuration
DB_PATH=./db/dashboard.db
DB_BACKUP_ENABLED=true
DB_BACKUP_INTERVAL=1800000
DB_BACKUP_RETENTION=10

# Security Configuration
# Admin password is configured via dashboard UI, not here
SESSION_TIMEOUT=86400000
MAX_LOGIN_ATTEMPTS=5
LOGIN_TIMEOUT=900000

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# Token Tracking Thresholds
TOKEN_THRESHOLD_HOURLY=100000
TOKEN_THRESHOLD_DAILY=1000000
TOKEN_THRESHOLD_COST_DAILY=50

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_RECONNECT_ATTEMPTS=5
WS_RECONNECT_DELAY=3000

# Monitoring Configuration
HEALTH_CHECK_INTERVAL=30000
METRICS_RETENTION_DAYS=30

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/dashboard.log
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=5

# MCP Services URLs (for monitoring)
CODEGEN_API_URL=http://localhost:8002
MEMORY_API_URL=http://localhost:8003
INTELLIGENCE_API_URL=http://localhost:8004
TOKEN_API_URL=http://localhost:8005
SDLC_API_URL=http://localhost:8006
LEGACY_API_URL=http://localhost:8007
SECURITY_API_URL=http://localhost:8008
PERFORMANCE_API_URL=http://localhost:8009
SCHEMA_API_URL=http://localhost:8011

# Feature Flags
ENABLE_HALLUCINATION_DETECTION=true
ENABLE_AUTO_BACKUP=true
ENABLE_METRICS_COLLECTION=true
ENABLE_AUDIT_LOGGING=true

# Performance Tuning
MAX_MEMORY_NODES=10000
MAX_LOG_ENTRIES=10000
CACHE_TTL=3600000